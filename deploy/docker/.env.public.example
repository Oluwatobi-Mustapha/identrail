# Optional overrides for deploy/docker/docker-compose.public.yml.
# The public-image quickstart works without this file; copy it only if you want
# to customize the default local ports, secrets, or image tag.

IDENTRAIL_IMAGE_REGISTRY=docker.io/identrail
IDENTRAIL_IMAGE_TAG=dev
IDENTRAIL_POSTGRES_PASSWORD=identrail-local-password
IDENTRAIL_WEB_PORT=8081
IDENTRAIL_API_KEYS=identrail-local-read-key-change-me,identrail-local-write-key-change-me
IDENTRAIL_WRITE_API_KEYS=identrail-local-write-key-change-me
IDENTRAIL_CORS_ALLOWED_ORIGINS=http://localhost:8081
IDENTRAIL_FEATURE_NEW_AUTH=true
IDENTRAIL_FEATURE_ONBOARDING_WIZARD=true
# Local-development only. /auth/manual mints a session from request-supplied
# identity. Startup refuses to boot with this true unless BOTH the public
# base URL is a loopback origin AND the server binds a loopback IDENTRAIL_HTTP_ADDR.
# This evaluation stack binds the container on :8080 but publishes the port
# only on the host loopback (127.0.0.1:8080:8080 in docker-compose.public.yml),
# so reachability is already constrained; ALLOW_UNSAFE acknowledges that and
# lets the guard pass. Never set ALLOW_UNSAFE on an internet-accessible host.
IDENTRAIL_AUTH_MANUAL_MODE=true
IDENTRAIL_AUTH_MANUAL_MODE_ALLOW_UNSAFE=true
IDENTRAIL_PUBLIC_BASE_URL=http://localhost:8080
# Optional: override the built-in localhost evaluation key before sharing or
# reusing the stack outside disposable local testing.
# IDENTRAIL_SESSION_KEY=replace-with-your-own-32-byte-minimum-session-key
