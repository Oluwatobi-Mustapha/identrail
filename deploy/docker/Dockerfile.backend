FROM golang:1.25.9-alpine@sha256:5caaf1cca9dc351e13deafbc3879fd4754801acba8653fa9540cea125d01a71f AS builder
WORKDIR /src

RUN apk add --no-cache ca-certificates tzdata git

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGET=server
ARG TARGETOS=linux
ARG TARGETARCH=amd64
RUN GOOS=${TARGETOS} GOARCH=${TARGETARCH} CGO_ENABLED=0 \
    go build -trimpath -ldflags="-s -w" -o /out/identrail ./cmd/${TARGET}

FROM alpine:3.22@sha256:310c62b5e7ca5b08167e4384c68db0fd2905dd9c7493756d356e893909057601
WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata git \
    && addgroup -S nonroot \
    && adduser -S -G nonroot -H -h /app nonroot \
    && git --version >/dev/null

COPY --from=builder /out/identrail /usr/local/bin/identrail
COPY --from=builder /src/migrations /app/migrations
COPY --from=builder /src/testdata /app/testdata

ENV IDENTRAIL_MIGRATIONS_DIR=/app/migrations
USER nonroot:nonroot

ENTRYPOINT ["/usr/local/bin/identrail"]
