# Core service settings
IDENTRAIL_SERVICE_NAME=identrail
IDENTRAIL_LOG_LEVEL=info
IDENTRAIL_PROVIDER=aws
IDENTRAIL_AWS_SOURCE=fixture
IDENTRAIL_AWS_REGION=us-east-1
# IDENTRAIL_AWS_PROFILE=default

# Auth (required)
IDENTRAIL_API_KEYS=replace-with-strong-read-key,replace-with-strong-write-key
IDENTRAIL_WRITE_API_KEYS=replace-with-strong-write-key

# Optional scoped auth alternative (takes precedence over API_KEYS)
# IDENTRAIL_API_KEY_SCOPES=reader-key:read;writer-key:read,write

# Provider fixture mode defaults (kept for deterministic local scans)
IDENTRAIL_K8S_SOURCE=fixture
IDENTRAIL_AWS_FIXTURES=/app/testdata/aws/role_with_policies.json,/app/testdata/aws/role_with_urlencoded_trust.json
IDENTRAIL_K8S_FIXTURES=/app/testdata/kubernetes/service_account_payments.json,/app/testdata/kubernetes/cluster_role_cluster_admin.json,/app/testdata/kubernetes/role_binding_cluster_admin.json,/app/testdata/kubernetes/pod_payments.json
# Optional live AWS collection via SDK:
# IDENTRAIL_AWS_SOURCE=sdk
# IDENTRAIL_AWS_REGION=us-east-1
# IDENTRAIL_AWS_PROFILE=default
# Optional live k8s collection via kubectl
# IDENTRAIL_K8S_SOURCE=kubectl
# IDENTRAIL_KUBECTL_PATH=/usr/bin/kubectl
# IDENTRAIL_KUBE_CONTEXT=dev-cluster

# Worker schedule
IDENTRAIL_SCAN_INTERVAL=15m
IDENTRAIL_WORKER_RUN_NOW=true

# Repo exposure scanner defaults
IDENTRAIL_REPO_SCAN_ENABLED=true
IDENTRAIL_REPO_SCAN_HISTORY_LIMIT=500
IDENTRAIL_REPO_SCAN_MAX_FINDINGS=200
IDENTRAIL_REPO_SCAN_HISTORY_LIMIT_MAX=5000
IDENTRAIL_REPO_SCAN_MAX_FINDINGS_MAX=1000
# Optional allowlist (comma-separated, supports prefix wildcard with *)
# IDENTRAIL_REPO_SCAN_ALLOWLIST=trusted-org/*,owner/repo

# API controls
IDENTRAIL_RATE_LIMIT_RPM=120
IDENTRAIL_RATE_LIMIT_BURST=20

# Optional alerts
# IDENTRAIL_ALERT_WEBHOOK_URL=https://alerts.example.com/identrail
# IDENTRAIL_ALERT_MIN_SEVERITY=high
# IDENTRAIL_ALERT_HMAC_SECRET=replace-with-secret
# IDENTRAIL_ALERT_MAX_RETRIES=2
# IDENTRAIL_ALERT_RETRY_BACKOFF=1s

# Web build API URL (must be HTTPS in production unless localhost)
VITE_IDENTRAIL_API_URL=http://localhost:8080
