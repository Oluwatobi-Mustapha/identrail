IDENTRAIL_SERVICE_NAME=identrail
IDENTRAIL_LOG_LEVEL=info
IDENTRAIL_PROVIDER=aws
IDENTRAIL_HTTP_ADDR=:8080
IDENTRAIL_AWS_SOURCE=fixture
IDENTRAIL_AWS_REGION=us-east-1
# IDENTRAIL_AWS_PROFILE=default

# Required auth settings
IDENTRAIL_API_KEYS=replace-read-key,replace-write-key
IDENTRAIL_WRITE_API_KEYS=replace-write-key

# Required persistence
IDENTRAIL_DATABASE_URL=postgres://identrail:replace-password@127.0.0.1:5432/identrail?sslmode=require
IDENTRAIL_RUN_MIGRATIONS=true
IDENTRAIL_MIGRATIONS_DIR=/opt/identrail/migrations

# Optional deterministic fixture mode
IDENTRAIL_K8S_SOURCE=fixture
IDENTRAIL_AWS_FIXTURES=/opt/identrail/testdata/aws/role_with_policies.json,/opt/identrail/testdata/aws/role_with_urlencoded_trust.json
IDENTRAIL_K8S_FIXTURES=/opt/identrail/testdata/kubernetes/service_account_payments.json,/opt/identrail/testdata/kubernetes/cluster_role_cluster_admin.json,/opt/identrail/testdata/kubernetes/role_binding_cluster_admin.json,/opt/identrail/testdata/kubernetes/pod_payments.json
# Optional live AWS collection:
# IDENTRAIL_AWS_SOURCE=sdk
# IDENTRAIL_AWS_REGION=us-east-1
# IDENTRAIL_AWS_PROFILE=default
# Optional live collection:
# IDENTRAIL_K8S_SOURCE=kubectl
# IDENTRAIL_KUBECTL_PATH=/usr/bin/kubectl
# IDENTRAIL_KUBE_CONTEXT=dev-cluster

# Worker schedule
IDENTRAIL_SCAN_INTERVAL=15m
IDENTRAIL_WORKER_RUN_NOW=true

# Repo exposure scanner defaults
IDENTRAIL_REPO_SCAN_ENABLED=true
IDENTRAIL_REPO_SCAN_HISTORY_LIMIT=500
IDENTRAIL_REPO_SCAN_MAX_FINDINGS=200
IDENTRAIL_REPO_SCAN_HISTORY_LIMIT_MAX=5000
IDENTRAIL_REPO_SCAN_MAX_FINDINGS_MAX=1000
# Optional allowlist:
# IDENTRAIL_REPO_SCAN_ALLOWLIST=trusted-org/*,owner/repo
