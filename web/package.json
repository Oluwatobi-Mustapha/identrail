    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.2"
