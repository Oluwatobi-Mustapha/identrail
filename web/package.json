{
  "name": "identrail-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run prerender:routes",
    "prerender:routes": "tsx ./scripts/prerender-routes.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "perf:lighthouse": "lhci autorun --config=./lighthouserc.json",
    "perf:bundle": "vite build --mode production"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/wasi-threads": "^1.2.1",
    "@lhci/cli": "0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "uuid": "9.0.1",
    "tmp": "^0.2.4",
    "@lhci/cli": {
      "uuid": "^9.0.1"
    }
  }
}
